{
  "manifest_version": 3,
  "name": "ClearFrame",
  "version": "0.1.0",
  "description": "Highlights euphemisms and framing terms with neutral alternatives and explanations.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/terms-index.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["terms-index.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ClearFrame"
  },
  "options_page": "options/options.html"
}
