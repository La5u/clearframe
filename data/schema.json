{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClearFrame Term Entry",
  "type": "object",
  "required": ["phrase", "type", "explanation"],
  "properties": {
    "phrase": { "type": "string", "minLength": 2 },
    "neutral": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "minLength": 2,
      "description": "Pattern type: euphemism, aggressive, sensational, framing, emotional, conflict, vague, or specific variants like clickbait, fear, moral, etc."
    },
    "explanation": { "type": "string", "minLength": 8 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "match": {
      "type": "object",
      "properties": {
        "context": {
          "type": "object",
          "properties": {
            "headlineOnly": { "type": "boolean" },
            "skipSelectors": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
